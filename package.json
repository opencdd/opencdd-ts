{
  "name": "@opencdd/opencdd",
  "version": "0.3.2",
  "description": "TypeScript port of the Ruby opencdd gem — read CDD data, output CDDAL.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencdd/opencdd-ts.git"
  },
  "homepage": "https://github.com/opencdd/opencdd-ts",
  "bugs": {
    "url": "https://github.com/opencdd/opencdd-ts/issues"
  },
  "keywords": [
    "cdd",
    "iec",
    "ontology",
    "common-data-dictionary",
    "opencdd",
    "parcel",
    "irdi"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
